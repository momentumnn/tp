<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane HBox.hgrow="ALWAYS">
    <columnConstraints>
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="150" />
    </columnConstraints>
    <VBox alignment="CENTER_LEFT" minHeight="105" GridPane.columnIndex="0">
      <padding>
        <Insets top="5" right="5" bottom="5" left="15" />
      </padding>

      <HBox alignment="CENTER_LEFT" spacing="10">
        <HBox alignment="CENTER_LEFT" spacing="5">
          <Label fx:id="id" styleClass="cell_big_label">
            <minWidth>
              <!-- Ensures that the label text is never truncated -->
              <Region fx:constant="USE_PREF_SIZE" />
            </minWidth>
          </Label>
          <Label fx:id="name" text="\$first" styleClass="cell_big_label" />
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="skill" styleClass="skill_tag_label" text="\$skill" />
      </HBox>

      <FlowPane fx:id="tags" />
      <VBox spacing="4">
        <Label fx:id="phone" styleClass="cell_small_label" text="\$phone" />
        <Label fx:id="address" styleClass="cell_small_label" text="\$address" />
        <Label fx:id="email" styleClass="cell_small_label" text="\$email" />
      </VBox>

      <Region styleClass="divider" prefHeight="1" minHeight="1" maxHeight="1">
        <VBox.margin>
          <Insets top="5" bottom="5" left="0" right="0" />
        </VBox.margin>
      </Region>

      <FlowPane fx:id="timeslots" hgap="5" vgap="5" />

      <VBox spacing="4">
        <Label fx:id="trainingGoal" styleClass="trainingGoal_label" text="\$trainingGoal" wrapText="true" />
        <Label fx:id="progressRecord" styleClass="progress_label" text="\$progressRecord" />
        <Label fx:id="injuryStatus" styleClass="injury_label" text="\$injuryStatus" />
      </VBox>
    </VBox>
  </GridPane>
</HBox>
